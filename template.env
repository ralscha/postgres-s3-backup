S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_PREFIX="backup"
S3_ENDPOINT=""
S3_ADDRESSING_MODE="path"

POSTGRES_HOST=""
POSTGRES_DATABASE="postgres"
POSTGRES_USER=""
POSTGRES_PASSWORD=""
POSTGRES_PORT="5432"

# Examples: @weekly, 12h, or cron syntax like 0 2 * * *.
SCHEDULE="@weekly"
BACKUP_KEEP_DAYS="7"

# Encryption: set either PASSPHRASE (scrypt/symmetric) or AGE_PUBLIC_KEY (X25519 asymmetric).
# For backups, these are mutually exclusive. Leave both empty to disable encryption.
# For restores of AGE_PUBLIC_KEY backups, set AGE_PUBLIC_KEY and put the private key identity in PASSPHRASE.
PASSPHRASE=""
AGE_PUBLIC_KEY=""
# scrypt work factor used with PASSPHRASE mode (default 18; higher = slower but stronger key derivation).
AGE_WORK_FACTOR="18"

PGDUMP_EXTRA_OPTS=""
PGDUMP_COMPRESS_LEVEL="6"
LOG_LEVEL="info"

# MODE: "backup" (default), "restore" or "list"
MODE="backup"
# RESTORE_TIMESTAMP: specific backup timestamp to restore (e.g. 2026-01-15T10:30:00).
# Leave empty to restore the latest available backup.
RESTORE_TIMESTAMP=""
